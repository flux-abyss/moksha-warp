# Python bytecode
__pycache__/
*.pyc
*.pyo

# Release tarballs and Debian source packages (generated by dev-mktar.sh or apt)
*.tar.gz
*.tar.xz
*.diff.gz
*.dsc
*.deb

# Build / packaging artifacts
build/
dist/
*.egg-info/
debian/.debhelper/
debian/tmp/
debian/files
debian/*.substvars

# Logs and machine-generated probe output
logs/*
!logs/proof/
!logs/proof/*.txt
logs/proof/*.log

# Temporary files
*.tmp
*.swp
*.swo
*~

# Python virtual environment
.venv/

# macOS / Windows junk
.DS_Store
Thumbs.db

# Local environment files
.env

# Upstream source trees (reference only – not vendored)
wayland-*/
wayland_*.dsc

# Local-only dev utilities (but NOT dev-mktar.sh which is a project tool)
dev-*.sh
!dev-mktar.sh
*.local.sh